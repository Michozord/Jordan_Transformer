@article{Banks2021,
author = {Banks, Jess and Kulkarni, Archit and Mukherjee, Satyaki and Srivastava, Nikhil},
title = {Gaussian Regularization of the Pseudospectrum and Davies’ Conjecture},
journal = {Communications on Pure and Applied Mathematics},
volume = {74},
number = {10},
pages = {2114-2131},
doi = {https://doi.org/10.1002/cpa.22017},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/cpa.22017},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/cpa.22017},
abstract = {Abstract A matrix is diagonalizable if it has a basis of linearly independent eigenvectors. Since the set of nondiagonalizable matrices has measure zero, every is the limit of diagonalizable matrices. We prove a quantitative version of this fact conjectured by E. B. Davies: for each , every matrix is at least -close to one whose eigenvectors have condition number at worst , for some depending only on n. We further show that the dependence on δ cannot be improved to for any constant . Our proof uses tools from random matrix theory to show that the pseudospectrum of A can be regularized with the addition of a complex Gaussian perturbation. Along the way, we explain how a variant of a theorem of Śniady implies a conjecture of Sankar, Spielman, and Teng on the optimal constant for smoothed analysis of condition numbers. © 2021 Wiley Periodicals, Inc.},
year = {2021}
}

